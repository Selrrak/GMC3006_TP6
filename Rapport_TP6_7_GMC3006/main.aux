\@writefile{toc}{\contentsline {section}{\numberline {1}Introduction}{1}{section.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {2}Étalonnage dynamique de thermocouples (TP 6)}{2}{section.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}But}{2}{subsection.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Graphiques}{2}{subsection.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1.1}{\ignorespaces Tension mesurée au bornes d’un thermocouple de 0.005 po de diamètre de jonction chaude lorsque plongé dans un bain d'eau glacée depuis une pièce à 23.9°C, avec une jonction de référence dans un autre bain d'eau glacée, acquise sur une gamme de -50 à 50 mV pendant trois secondes à une fréquence de 10 kHz, ainsi que la courbe de tendance modèlisée à partir des donnés. Les donnés ont été recadrées pour exclure le temps d'acquisition antérieur à la plongée afin d'ameliorer la qualité du modèle exponentiel. Le terme au dénominateur de l éxposant est la constante de temps recherchée. On observe un régime stationnaire non nul, ce qui est causé par une différence température entre la référence et le bain dans lequel eest plongé la jonction chaude. Cela n'a pas d'effet sur le régime transitoire. Les points ne sont pas liés entre eux pour apprécier l'effet de la fréquence et de la gamme d'acquisition sur la prise de mesures.}}{2}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:TC_0005}{{1.1}{2}{Tension mesurée au bornes d’un thermocouple de 0.005 po de diamètre de jonction chaude lorsque plongé dans un bain d'eau glacée depuis une pièce à 23.9°C, avec une jonction de référence dans un autre bain d'eau glacée, acquise sur une gamme de -50 à 50 mV pendant trois secondes à une fréquence de 10 kHz, ainsi que la courbe de tendance modèlisée à partir des donnés. Les donnés ont été recadrées pour exclure le temps d'acquisition antérieur à la plongée afin d'ameliorer la qualité du modèle exponentiel. Le terme au dénominateur de l éxposant est la constante de temps recherchée. On observe un régime stationnaire non nul, ce qui est causé par une différence température entre la référence et le bain dans lequel eest plongé la jonction chaude. Cela n'a pas d'effet sur le régime transitoire. Les points ne sont pas liés entre eux pour apprécier l'effet de la fréquence et de la gamme d'acquisition sur la prise de mesures}{figure.caption.2}{}}
\newlabel{fig:TC_0005@cref}{{[figure][1][1]1.1}{[1][2][]2}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.2}{\ignorespaces Tension mesurée au bornes d’un thermocouple de 0.010 po de diamètre de jonction chaude lorsque plongé dans un bain d'eau glacée depuis une pièce à 23.9°C, avec une jonction de référence dans un autre bain d'eau glacée, acquise sur une gamme de -50 à 50 mV pendant trois secondes à une fréquence de 10 kHz, ainsi que la courbe de tendance modèlisée à partir des donnés.}}{3}{figure.caption.3}\protected@file@percent }
