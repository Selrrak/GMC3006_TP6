\@writefile{toc}{\contentsline {section}{\numberline {4}Étalonnage statique de Thermocouples (TP 7)}{9}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}But}{9}{subsection.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Graphiques}{9}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces Mesures de tension (mV) en fonction de la température (°C) sur une plage de -10 à 80 °C, avec un incrément de 10 °C, après atteinte du régime stationnaire, pour différents types de thermocouple avec leurs courbes de régressions respectives. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe, et celles de tensions sont en fait des moyennes arithmétiques de 100 points enregistrés à 50 Hz. La gamme d'acquisition est de -50 mV à 50 mV. La ligne à 0 mV est identifiée dans le graphique pour souligner la température de référence des thermocouples. }}{9}{figure.caption.9}\protected@file@percent }
\newlabel{fig:stat_all}{{2.1}{9}{Mesures de tension (mV) en fonction de la température (°C) sur une plage de -10 à 80 °C, avec un incrément de 10 °C, après atteinte du régime stationnaire, pour différents types de thermocouple avec leurs courbes de régressions respectives. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe, et celles de tensions sont en fait des moyennes arithmétiques de 100 points enregistrés à 50 Hz. La gamme d'acquisition est de -50 mV à 50 mV. La ligne à 0 mV est identifiée dans le graphique pour souligner la température de référence des thermocouples}{figure.caption.9}{}}
\newlabel{fig:stat_all@cref}{{[figure][1][2]2.1}{[1][9][]9}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.2}{\ignorespaces Mesures de tension (mV) en fonction de la température (°C) pour un thermocouple de type E, après atteinte du régime stationnaire, avec les valeurs NBS correspondante pour une plage de -10 à 80 °C. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe. }}{10}{figure.caption.10}\protected@file@percent }
\newlabel{fig:stat_E}{{2.2}{10}{Mesures de tension (mV) en fonction de la température (°C) pour un thermocouple de type E, après atteinte du régime stationnaire, avec les valeurs NBS correspondante pour une plage de -10 à 80 °C. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe}{figure.caption.10}{}}
\newlabel{fig:stat_E@cref}{{[figure][2][2]2.2}{[1][9][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.3}{\ignorespaces Mesures de tension (mV) en fonction de la température (°C) pour un thermocouple de type K, après atteinte du régime stationnaire, avec les valeurs NBS correspondante pour une plage de -10 à 80 °C. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe. }}{10}{figure.caption.11}\protected@file@percent }
