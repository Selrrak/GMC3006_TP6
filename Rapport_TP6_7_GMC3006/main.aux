\newlabel{fig:stat_K@cref}{{[figure][3][2]2.3}{[1][10][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.4}{\ignorespaces Mesures de tension (mV) en fonction de la température (°C) pour un thermocouple de type J, après atteinte du régime stationnaire, avec les valeurs NBS correspondante pour une plage de -10 à 80 °C. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe. }}{11}{figure.caption.12}\protected@file@percent }
