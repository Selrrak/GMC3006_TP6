\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces Mesures de tension (mV) en fonction de la température (°C) sur une plage de -10 à 80 °C, avec un incrément de 10 °C, pour différents types de thermocouple avec leurs courbes de régressions respectives. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe. La ligne à 0 mV est identifiée pour souligner la température de référence des thermocouples. }}{11}{figure.caption.9}\protected@file@percent }
\newlabel{fig:stat_tout_type}{{2.1}{11}{Mesures de tension (mV) en fonction de la température (°C) sur une plage de -10 à 80 °C, avec un incrément de 10 °C, pour différents types de thermocouple avec leurs courbes de régressions respectives. Les mesures ont été prises dans une unité d'étalonnage CL500 de la compagnie Omega. Celles de température ont été prises avec une sonde RTD externe. La ligne à 0 mV est identifiée pour souligner la température de référence des thermocouples}{figure.caption.9}{}}
\newlabel{fig:stat_tout_type@cref}{{[figure][1][2]2.1}{[1][11][]11}{}{}{}}
